{
  "name": "@riddance/env",
  "version": "0.9.10",
  "type": "module",
  "keywords": [
    "riddance",
    "environment",
    "devenv",
    "opinionated"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.14"
  },
  "dependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "^22",
    "cspell-lib": "10.0.0",
    "eslint": "10.4.0",
    "@eslint/js": "10.0.1",
    "globals": "17.6.0",
    "typescript-eslint": "8.59.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-n": "18.0.1",
    "eslint-plugin-prefer-arrow-functions": "3.9.1",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-unicorn": "64.0.0",
    "mocha": "12.0.0-beta-9.3",
    "prettier": "3.8.3",
    "source-map-support": "0.5.21",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@types/eslint": "9.6.1",
    "@types/eslint-plugin-prettier": "3.1.3",
    "@types/source-map-support": "0.5.10"
  },
  "scripts": {
    "prepare": "tsc && node ./bin/prepare.js",
    "start": "npm run prepare && node ./bin/install.js && node ./bin/watch.js",
    "prepack": "npm run prepare && node ./bin/build.js",
    "prepublishOnly": "tsc && node ./bin/prepublish.js",
    "postpublish": "node ./bin/sync.js",
    "postinstall": "node ./bin/install.js || (tsc && node ./bin/install.js)"
  },
  "files": [
    "/*.js",
    "**/lib/*.js",
    "/template/**",
    "/bin/install.js",
    "instructions.md"
  ],
  "bin": {
    "riddance-watch": "./bin/watch.js",
    "riddance-build": "./bin/build.js",
    "riddance-fix": "./bin/fix.js",
    "riddance-prepublish": "./bin/prepublish.js",
    "riddance-sync": "./bin/sync.js"
  },
  "ai": {
    "instructions": "./instructions.md"
  }
}
